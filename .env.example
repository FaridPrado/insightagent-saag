# Copia este archivo como .env
# En PowerShell: copy .env.example .env

# Activa o desactiva el agente LLM. Si no configuras ninguna API key, la app usa análisis local seguro.
LLM_ENABLED=true
LLM_TIMEOUT_SECONDS=28
LLM_RETRIES_PER_PROVIDER=2
LLM_TEMPERATURE=0.15

# Orden recomendado para demos públicas: Gemini principal, OpenRouter/Cerebras como fallback y Groq al final.
LLM_PROVIDER_ORDER=gemini,openrouter,cerebras,groq

# Google AI Studio / Gemini API
# Recomendado para demo: Gemini Flash.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenRouter fallback. openrouter/free enruta a modelos gratuitos disponibles.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
OPENROUTER_SITE_URL=http://localhost:8000
OPENROUTER_APP_NAME=InsightAgent

# Cerebras fallback.
CEREBRAS_API_KEY=
CEREBRAS_MODEL=gpt-oss-120b

# Groq fallback opcional.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile


# Frontend allowed origins for CORS.
# Use exact origins without trailing slash.
# Examples:
# CORS_ORIGINS=https://insightagent-saag.vercel.app
# CORS_ORIGINS=https://insightagent-saag.vercel.app,http://localhost:3000,http://127.0.0.1:8000
CORS_ORIGINS=

# Environment label returned by /health and /api/health.
APP_ENV=development
